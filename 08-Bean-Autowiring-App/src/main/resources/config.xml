<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
     
     
      
     <bean id = "reportManager" class = "com.tca.bean.ReportManager" autowire =" byType">
       <property name = "page" value = "10"/>
     </bean>
     <bean id = "pdfReportCreater" class = "com.tca.bean.PdfReportCreater" primary="true"/>
     <bean id = "exlReportCreater" class = "com.tca.bean.ExlReportCreater"/>
     
</beans> 